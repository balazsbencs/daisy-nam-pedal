diff --git a/test/test_namb.cpp b/test/test_namb.cpp
index e679092..52ae852 100644
--- a/test/test_namb.cpp
+++ b/test/test_namb.cpp
@@ -181,6 +181,110 @@ void test_roundtrip()
 // Format validation tests
 // =============================================================================
 
+static void set_u32(std::vector<uint8_t>& data, size_t offset, uint32_t value)
+{
+  std::memcpy(data.data() + offset, &value, sizeof(value));
+}
+
+static void refresh_checksum(std::vector<uint8_t>& data)
+{
+  set_u32(data, 24, 0);
+  set_u32(data, 24, nam::namb::compute_file_crc32(data.data(), data.size()));
+}
+
+static std::vector<uint8_t> minimal_namb(size_t size = nam::namb::MODEL_BLOCK_OFFSET)
+{
+  std::vector<uint8_t> data(size, 0);
+  set_u32(data, 0, nam::namb::MAGIC);
+  uint16_t version = nam::namb::FORMAT_VERSION;
+  std::memcpy(data.data() + 4, &version, sizeof(version));
+  set_u32(data, 8, static_cast<uint32_t>(size));
+  set_u32(data, 12, nam::namb::MODEL_BLOCK_OFFSET);
+  data[nam::namb::FILE_HEADER_SIZE + 1] = 7; // supported model config version 0.7.0
+  refresh_checksum(data);
+  return data;
+}
+
+static void expect_layout_error(const std::vector<uint8_t>& data, const char* text)
+{
+  bool threw = false;
+  try
+  {
+    nam::get_dsp_namb(data.data(), data.size());
+  }
+  catch (const std::runtime_error& e)
+  {
+    threw = true;
+    if (std::string(e.what()).find(text) == std::string::npos)
+      std::cerr << "Expected error containing '" << text << "', got '" << e.what() << "'\n";
+    assert(std::string(e.what()).find(text) != std::string::npos);
+  }
+  assert(threw);
+}
+
+void test_null_buffer()
+{
+  bool threw = false;
+  try
+  {
+    nam::get_dsp_namb(nullptr, nam::namb::MODEL_BLOCK_OFFSET);
+  }
+  catch (const std::runtime_error& e)
+  {
+    threw = true;
+    assert(std::string(e.what()).find("null") != std::string::npos);
+  }
+  assert(threw);
+}
+
+void test_weights_before_model_block()
+{
+  auto data = minimal_namb();
+  set_u32(data, 12, nam::namb::MODEL_BLOCK_OFFSET - 1);
+  set_u32(data, 20, 0);
+  refresh_checksum(data);
+  expect_layout_error(data, "offset");
+}
+
+void test_unaligned_weights()
+{
+  auto data = minimal_namb(nam::namb::MODEL_BLOCK_OFFSET + 4);
+  set_u32(data, 12, nam::namb::MODEL_BLOCK_OFFSET + 1);
+  set_u32(data, 20, 1);
+  refresh_checksum(data);
+  expect_layout_error(data, "aligned");
+}
+
+void test_excessive_weight_count()
+{
+  auto data = minimal_namb();
+  set_u32(data, 16, UINT32_MAX);
+  refresh_checksum(data);
+  expect_layout_error(data, "weights");
+}
+
+void test_inconsistent_model_block_size()
+{
+  auto data = minimal_namb(nam::namb::MODEL_BLOCK_OFFSET + 4);
+  set_u32(data, 12, nam::namb::MODEL_BLOCK_OFFSET + 4);
+  set_u32(data, 20, 3);
+  refresh_checksum(data);
+  expect_layout_error(data, "model block");
+}
+
+void test_condition_weights_exceed_model_weights()
+{
+  auto data = minimal_namb(nam::namb::MODEL_BLOCK_OFFSET + 12);
+  set_u32(data, 12, static_cast<uint32_t>(data.size()));
+  set_u32(data, 20, 12);
+  data[nam::namb::MODEL_BLOCK_OFFSET] = nam::namb::ARCH_WAVENET;
+  data[nam::namb::MODEL_BLOCK_OFFSET + 4] = 1; // input channels
+  data[nam::namb::MODEL_BLOCK_OFFSET + 7] = 1; // condition DSP present
+  set_u32(data, nam::namb::MODEL_BLOCK_OFFSET + 8, 1);
+  refresh_checksum(data);
+  expect_layout_error(data, "condition DSP weights");
+}
