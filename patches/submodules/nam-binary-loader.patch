+bool film_inactive(const nam::wavenet::_FiLMParams& p)
+{
+  // shift/groups only affect active FiLM blocks. NAM files commonly retain
+  // shift=true in an inactive block, which must not disqualify an A2 model.
+  return !p.active;
+}
+
+bool activation_is_a2_leaky_relu(const nam::activations::ActivationConfig& c)
+{
+  return c.type == nam::activations::ActivationType::LeakyReLU
+         && c.negative_slope.has_value()
+         && std::abs(*c.negative_slope - nam::wavenet::a2_fast::kLeakySlope) < 1.0e-6f;
+}
+
+bool is_a2_wavenet_config(const nam::wavenet::WaveNetConfig& wc, int* channels)
+{
+  using nam::wavenet::a2_fast::kDilations;
+  using nam::wavenet::a2_fast::kHeadKernelSize;
+  using nam::wavenet::a2_fast::kKernelSizes;
+  using nam::wavenet::a2_fast::kNumLayers;
+
+  if (wc.in_channels != 1 || wc.with_head || wc.condition_dsp || wc.layer_array_params.size() != 1)
+    return false;
+
+  const auto& la = wc.layer_array_params[0];
+  if (la.input_size != 1 || la.condition_size != 1 || la.head_size != 1)
+    return false;
+  if (la.channels != la.bottleneck)
+    return false;
+#if defined(NAM_A2_NANO_ONLY)
+  if (la.channels != 3)
+#else
+  if (la.channels != 3 && la.channels != 8)
+#endif
+    return false;
+  if (la.head_kernel_size != kHeadKernelSize || !la.head_bias)
+    return false;
+  if (la.groups_input != 1 || la.groups_input_mixin != 1)
+    return false;
+  if (!la.layer1x1_params.active || la.layer1x1_params.groups != 1)
+    return false;
+  if (la.head1x1_params.active)
+    return false;
+  if (la.kernel_sizes.size() != kNumLayers || la.dilations.size() != kNumLayers
+      || la.activation_configs.size() != kNumLayers || la.gating_modes.size() != kNumLayers)
+    return false;
+
+  for (int i = 0; i < kNumLayers; ++i)
+  {
+    if (la.kernel_sizes[i] != kKernelSizes[i] || la.dilations[i] != kDilations[i])
+      return false;
+    if (!activation_is_a2_leaky_relu(la.activation_configs[i]))
+      return false;
+    if (la.gating_modes[i] != nam::wavenet::GatingMode::NONE)
+      return false;
+  }
+
+  if (!film_inactive(la.conv_pre_film_params) || !film_inactive(la.conv_post_film_params)
+      || !film_inactive(la.input_mixin_pre_film_params) || !film_inactive(la.input_mixin_post_film_params)
+      || !film_inactive(la.activation_pre_film_params) || !film_inactive(la.activation_post_film_params)
+      || !film_inactive(la._layer1x1_post_film_params) || !film_inactive(la.head1x1_post_film_params))
+    return false;
+
+  if (channels)
+    *channels = la.channels;
+  return true;
+}
+#endif
